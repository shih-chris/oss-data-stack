# Example environment variables for oss-data-stack
# scripts/setup_gcp.sh can generate a local .env with these values.

# GCP configuration
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-central1

# Cloud SQL PostgreSQL catalog
CLOUD_SQL_INSTANCE=ducklake-postgres
CLOUD_SQL_CONNECTION_NAME=your-gcp-project-id:us-central1:ducklake-postgres
DUCKLAKE_PG_HOST=127.0.0.1
DUCKLAKE_PG_PORT=5432
DUCKLAKE_PG_DATABASE=ducklake_catalog
DUCKLAKE_PG_USER=postgres
DUCKLAKE_PG_PASSWORD=replace-me

# GCS object storage
GOOGLE_APPLICATION_CREDENTIALS=config/keys/ducklake-service-account.json
DUCKLAKE_GCS_BUCKET=your-gcp-project-id-ducklake
DUCKLAKE_GCS_PREFIX=ducklake
DUCKLAKE_GCS_PATH=gs://your-gcp-project-id-ducklake/ducklake
DUCKLAKE_GCS_HMAC_KEY_ID=replace-me
DUCKLAKE_GCS_HMAC_SECRET=replace-me

# DuckLake attach/catalog settings
DUCKLAKE_CATALOG_NAME=ducklake
DUCKLAKE_METADATA_SCHEMA=ducklake
DUCKLAKE_SECRET_NAME=ducklake_secret
DUCKLAKE_POSTGRES_SECRET_NAME=ducklake_postgres
DUCKLAKE_GCS_SECRET_NAME=ducklake_gcs

# USGS API Configuration (optional - has defaults)
USGS_BASE_URL=https://waterservices.usgs.gov/nwis/iv/
USGS_SITE_CODES=03076500
USGS_PARAMETER_CODES=00065

# dlt Configuration
DLT_PROJECT_DIR=.
DLT_CONFIG_PATH=config/dlt/config.toml

# Dagster Configuration
DAGSTER_HOME=storage/dagster_home

# Dagster Cloud Run / Cloud SQL metadata storage
DAGSTER_PG_DATABASE=dagster
DAGSTER_PG_USER=postgres
DAGSTER_POSTGRES_URL=postgresql://postgres:replace-me@/dagster?host=%2Fcloudsql%2Fyour-gcp-project-id%3Aus-central1%3Aducklake-postgres

# Cloud Run deployment
ARTIFACT_REPOSITORY=oss-data-stack
DAGSTER_IMAGE_NAME=dagster
DAGSTER_RUNTIME_SERVICE_ACCOUNT=dagster-runtime
DAGSTER_WEBSERVER_SERVICE=dagster-webserver
DAGSTER_DAEMON_SERVICE=dagster-daemon
DAGSTER_WEBSERVER_ALLOW_UNAUTHENTICATED=0
DAGSTER_WEBSERVER_INGRESS=all

# Secret Manager secret names
DUCKLAKE_PG_PASSWORD_SECRET=ducklake-pg-password
DUCKLAKE_GCS_HMAC_KEY_ID_SECRET=ducklake-gcs-hmac-key-id
DUCKLAKE_GCS_HMAC_SECRET_SECRET=ducklake-gcs-hmac-secret
DAGSTER_POSTGRES_URL_SECRET=dagster-postgres-url
GRAFANA_LOKI_URL_SECRET=grafana-cloud-loki-url
GRAFANA_LOKI_USER_SECRET=grafana-cloud-loki-user
GRAFANA_LOKI_API_KEY_SECRET=grafana-cloud-loki-api-key
GRAFANA_ALLOY_CONFIG_SECRET=grafana-alloy-config

# Grafana Cloud Loki (used by scripts/setup_dagster_gcp.sh to create secrets)
LOKI_URL=https://logs-prod-000.grafana.net/loki/api/v1/push
LOKI_USER=replace-me
LOKI_API_KEY=replace-me

# GitHub Actions Workload Identity Federation (optional)
GITHUB_REPOSITORY=your-github-org-or-user/oss-data-stack
GITHUB_WIF_POOL=github-actions
GITHUB_WIF_PROVIDER=github
GITHUB_DEPLOY_SERVICE_ACCOUNT=github-dagster-deployer
